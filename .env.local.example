# Copia este archivo a .env.local y completa los valores reales.
# Nunca compartas estos valores en un chat ni los subas a git — este
# archivo es solo una plantilla y .env.local ya está en .gitignore.

# Clave para entrar a /dashboard (ver /unlock). Elige cualquier frase.
SITE_PASSWORD=

# Panel de Supabase > Project Settings > API.
# OJO: SUPABASE_SERVICE_ROLE_KEY tiene acceso total e ignora RLS.
# Solo se usa en el servidor (src/lib/supabase/admin.ts) y jamás debe
# llevar el prefijo NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
