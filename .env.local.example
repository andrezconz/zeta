# Copia este archivo a .env.local y completa los valores reales.
# Mientras estas variables no existan, Fortis funciona en modo demo con
# datos simulados (src/lib/data/mock-data.ts) y sin autenticación real.

# Panel de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Panel de Supabase > Project Settings > Database > Connection string
# DATABASE_URL usa el pooler (puerto 6543), DIRECT_URL la conexión directa
# (puerto 5432), necesaria para correr migraciones de Prisma.
DATABASE_URL=
DIRECT_URL=
