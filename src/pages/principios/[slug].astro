---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const principios = await getCollection('principios');
  return principios.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('principios')).sort(
  (a, b) => a.data.numero - b.data.numero,
);
const index = all.findIndex((p) => p.id === entry.id);
const prev = index > 0 ? all[index - 1] : null;
const next = index < all.length - 1 ? all[index + 1] : null;
---

<Layout title={`${entry.data.numero}. ${entry.data.titulo}`} description={entry.data.resumen}>
  <p class="eyebrow">Principio {entry.data.numero} de 15</p>
  <h1>{entry.data.titulo}</h1>
  {entry.data.autores.length > 0 && (
    <p style="color: var(--color-ink-soft); font-size: 0.9rem;">
      Asociado con: {entry.data.autores.join(', ')}
    </p>
  )}

  <Content />

  <nav class="pager">
    {prev ? <a href={`/principios/${prev.id}`}>&larr; {prev.data.numero}. {prev.data.titulo}</a> : <span />}
    {next ? <a href={`/principios/${next.id}`}>{next.data.numero}. {next.data.titulo} &rarr;</a> : <span />}
  </nav>

  <p><a href="/principios">&larr; Ver todos los principios</a></p>
</Layout>
