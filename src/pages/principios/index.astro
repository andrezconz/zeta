---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const principios = (await getCollection('principios')).sort(
  (a, b) => a.data.numero - b.data.numero,
);
---

<Layout title="Los 15 principios">
  <p class="eyebrow">Índice</p>
  <h1>Los 15 principios</h1>
  <p>
    Patrones comunes entre Benjamin Graham, Warren Buffett, Charlie Munger, Ray
    Dalio, Peter Lynch, Howard Marks y John C. Bogle.
  </p>

  <div class="grid principios">
    {principios.map((p) => (
      <a class="card card-link" href={`/principios/${p.id}`}>
        <span class="badge-number">{p.data.numero}</span>
        <h3 style="margin-top:0">{p.data.titulo}</h3>
        <p style="margin-bottom:0; color: var(--color-ink-soft); font-size:0.92rem;">
          {p.data.resumen}
        </p>
      </a>
    ))}
  </div>
</Layout>
