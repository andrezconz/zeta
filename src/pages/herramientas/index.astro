---
import Layout from '../../layouts/Layout.astro';

const herramientas = [
  {
    href: '/herramientas/calculadora-interes-compuesto',
    titulo: 'Calculadora de interés compuesto',
    resumen: 'Simula el crecimiento de tu capital con aportes periódicos (principio 5).',
    icon: '📈',
  },
  {
    href: '/herramientas/checklist-revision',
    titulo: 'Checklist de revisión periódica',
    resumen: 'Revisa presupuesto, patrimonio, deudas y portafolio (principio 15).',
    icon: '✅',
  },
  {
    href: '/herramientas/objetivos-smart',
    titulo: 'Definidor de objetivos SMART',
    resumen: 'Registra tus metas financieras con monto y horizonte de tiempo (principio 1).',
    icon: '🎯',
  },
  {
    href: '/herramientas/portafolio',
    titulo: 'Portafolio',
    resumen: 'Seguimiento de posiciones y asignación de activos.',
    icon: '📊',
    proximamente: true,
  },
];
---

<Layout title="Herramientas estratégicas">
  <p class="eyebrow">Herramientas</p>
  <h1>Herramientas estratégicas</h1>
  <p>
    Ejercicios prácticos para aplicar los principios del plan financiero.
    Todo el cálculo ocurre en tu navegador; nada se envía a un servidor.
  </p>

  <div class="grid herramientas">
    {herramientas.map((h) => (
      <a class="card card-link" href={h.href}>
        <div style="font-size:1.6rem; margin-bottom:0.4rem;">{h.icon}</div>
        <h3 style="margin-top:0">
          {h.titulo}
          {h.proximamente && (
            <span style="font-size:0.7rem; font-weight:600; color: var(--color-accent-dark); margin-left:0.4rem;">
              EN CONSTRUCCIÓN
            </span>
          )}
        </h3>
        <p style="margin-bottom:0; color: var(--color-ink-soft); font-size:0.92rem;">
          {h.resumen}
        </p>
      </a>
    ))}
  </div>
</Layout>
