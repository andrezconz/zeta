---
import Layout from '../../layouts/Layout.astro';

const tipos = [
  'Independencia financiera',
  'Generación de ingresos pasivos',
  'Protección del patrimonio',
  'Crecimiento del capital',
  'Jubilación',
  'Educación de los hijos',
  'Compra de vivienda',
  'Otro',
];
---

<Layout
  title="Definidor de objetivos SMART"
  description="Registra tus objetivos financieros con un monto y un horizonte de tiempo definidos, según el principio 1."
>
  <p class="eyebrow">Herramienta &middot; Principio 1</p>
  <h1>Definidor de objetivos SMART</h1>
  <p>
    Toda inversión debe responder a una meta específica y a un horizonte de
    tiempo determinado. Registra tus objetivos y calcula cuánto necesitas
    ahorrar cada mes para alcanzarlos.
  </p>

  <form class="tool-form" id="goal-form">
    <label for="nombre">Nombre de la meta</label>
    <input type="text" id="nombre" name="nombre" placeholder="Ej. Cuota inicial de vivienda" required />

    <label for="tipo">Tipo de objetivo</label>
    <select id="tipo" name="tipo">
      {tipos.map((t) => <option value={t}>{t}</option>)}
    </select>

    <label for="monto">Monto objetivo (USD)</label>
    <input type="number" id="monto" name="monto" min="0" step="100" required />

    <label for="ahorrado">Ya ahorrado hasta hoy (USD)</label>
    <input type="number" id="ahorrado" name="ahorrado" min="0" step="100" value="0" />

    <label for="fecha">Fecha límite</label>
    <input type="date" id="fecha" name="fecha" required />

    <button type="submit">Agregar objetivo</button>
  </form>

  <h2>Mis objetivos</h2>
  <div id="goal-list"></div>
  <p class="empty-state" id="empty-state">Aún no has registrado objetivos.</p>

  <script>
    interface Goal {
      id: string;
      nombre: string;
      tipo: string;
      monto: number;
      ahorrado: number;
      fecha: string;
    }

    const STORAGE_KEY = 'zeta-objetivos-smart';
    const form = document.getElementById('goal-form') as HTMLFormElement;
    const list = document.getElementById('goal-list') as HTMLDivElement;
    const emptyState = document.getElementById('empty-state') as HTMLParagraphElement;

    const money = (n: number) =>
      n.toLocaleString('es-CO', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

    function load(): Goal[] {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function save(goals: Goal[]) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(goals));
    }

    function mesesRestantes(fecha: string): number {
      const hoy = new Date();
      const limite = new Date(fecha);
      const diffMs = limite.getTime() - hoy.getTime();
      const meses = diffMs / (1000 * 60 * 60 * 24 * 30.4);
      return Math.max(Math.ceil(meses), 1);
    }

    function render() {
      const goals = load();
      list.innerHTML = '';
      emptyState.style.display = goals.length === 0 ? 'block' : 'none';

      goals.forEach((goal) => {
        const restante = Math.max(goal.monto - goal.ahorrado, 0);
        const meses = mesesRestantes(goal.fecha);
        const ahorroMensual = restante / meses;
        const progreso = goal.monto > 0 ? Math.min((goal.ahorrado / goal.monto) * 100, 100) : 0;

        const el = document.createElement('div');
        el.className = 'card goal-item';
        el.innerHTML = `
          <h3 style="margin:0 0 0.2rem;">${goal.nombre}</h3>
          <div class="eyebrow">${goal.tipo}</div>
          <div class="progress-track"><div class="progress-fill" style="width:${progreso}%"></div></div>
          <div class="goal-meta">
            <span>Meta: ${money(goal.monto)}</span>
            <span>Ahorrado: ${money(goal.ahorrado)}</span>
            <span>Fecha límite: ${goal.fecha}</span>
            <span>Ahorro mensual necesario: <strong>${money(ahorroMensual)}</strong></span>
          </div>
          <button class="remove" data-id="${goal.id}">Eliminar</button>
        `;
        list.appendChild(el);
      });

      list.querySelectorAll('button.remove').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLButtonElement).dataset.id;
          const remaining = load().filter((g) => g.id !== id);
          save(remaining);
          render();
        });
      });
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const goals = load();
      goals.push({
        id: crypto.randomUUID(),
        nombre: (document.getElementById('nombre') as HTMLInputElement).value,
        tipo: (document.getElementById('tipo') as HTMLSelectElement).value,
        monto: parseFloat((document.getElementById('monto') as HTMLInputElement).value) || 0,
        ahorrado: parseFloat((document.getElementById('ahorrado') as HTMLInputElement).value) || 0,
        fecha: (document.getElementById('fecha') as HTMLInputElement).value,
      });
      save(goals);
      form.reset();
      render();
    });

    render();
  </script>
</Layout>
