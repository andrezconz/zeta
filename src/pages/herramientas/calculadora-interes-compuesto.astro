---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Calculadora de interés compuesto"
  description="Simula el crecimiento de tu capital con aportes periódicos y una tasa de rendimiento esperada."
>
  <p class="eyebrow">Herramienta &middot; Principio 5</p>
  <h1>Calculadora de interés compuesto</h1>
  <p>
    Las ganancias reinvertidas generan nuevas ganancias. Ajusta los valores para
    ver cómo el tiempo y la constancia multiplican tu capital.
  </p>

  <form class="tool-form" id="calc-form">
    <label for="inicial">Aporte inicial (USD)</label>
    <input type="number" id="inicial" name="inicial" min="0" step="100" value="1000" />

    <label for="mensual">Aporte mensual (USD)</label>
    <input type="number" id="mensual" name="mensual" min="0" step="10" value="200" />

    <label for="tasa">Tasa de rendimiento anual esperada (%)</label>
    <input type="number" id="tasa" name="tasa" min="0" step="0.1" value="8" />

    <label for="anios">Horizonte de tiempo (años)</label>
    <input type="number" id="anios" name="anios" min="1" step="1" value="20" />

    <button type="submit">Calcular</button>
  </form>

  <div class="result-box" id="resultado" style="display:none;">
    <div class="stat">
      <span>Total aportado</span>
      <span id="r-aportado">$0</span>
    </div>
    <div class="stat">
      <span>Interés generado</span>
      <span id="r-interes">$0</span>
    </div>
    <div class="stat">
      <span>Valor final estimado</span>
      <span id="r-final">$0</span>
    </div>
  </div>

  <script>
    const form = document.getElementById('calc-form') as HTMLFormElement;
    const resultado = document.getElementById('resultado') as HTMLDivElement;
    const rAportado = document.getElementById('r-aportado')!;
    const rInteres = document.getElementById('r-interes')!;
    const rFinal = document.getElementById('r-final')!;

    const money = (n: number) =>
      n.toLocaleString('es-CO', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

    function calcular() {
      const inicial = parseFloat((document.getElementById('inicial') as HTMLInputElement).value) || 0;
      const mensual = parseFloat((document.getElementById('mensual') as HTMLInputElement).value) || 0;
      const tasaAnual = parseFloat((document.getElementById('tasa') as HTMLInputElement).value) || 0;
      const anios = parseFloat((document.getElementById('anios') as HTMLInputElement).value) || 0;

      const meses = Math.round(anios * 12);
      const tasaMensual = tasaAnual / 100 / 12;

      let valorInicialCompuesto: number;
      let valorAportesCompuesto: number;

      if (tasaMensual === 0) {
        valorInicialCompuesto = inicial;
        valorAportesCompuesto = mensual * meses;
      } else {
        valorInicialCompuesto = inicial * Math.pow(1 + tasaMensual, meses);
        valorAportesCompuesto =
          mensual * ((Math.pow(1 + tasaMensual, meses) - 1) / tasaMensual);
      }

      const valorFinal = valorInicialCompuesto + valorAportesCompuesto;
      const totalAportado = inicial + mensual * meses;
      const interesGenerado = valorFinal - totalAportado;

      rAportado.textContent = money(totalAportado);
      rInteres.textContent = money(Math.max(interesGenerado, 0));
      rFinal.textContent = money(valorFinal);
      resultado.style.display = 'block';
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      calcular();
    });

    calcular();
  </script>
</Layout>
