---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/principios', label: 'Principios' },
  { href: '/herramientas', label: 'Herramientas' },
];
const current = Astro.url.pathname;
---

<header class="site-nav">
  <div class="site-nav-inner">
    <a class="brand" href="/">Zeta &middot; Plan Financiero</a>
    <nav>
      {links.map((link) => {
        const active =
          link.href === '/' ? current === '/' : current.startsWith(link.href);
        return (
          <a href={link.href} class={active ? 'active' : ''}>
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .site-nav {
    background: var(--color-ink);
    color: #fff;
  }

  .site-nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 0.92rem;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }

  nav a:hover {
    color: #fff;
  }

  nav a.active {
    color: #fff;
    border-bottom-color: var(--color-accent);
  }
</style>
